# Local Development Environment Variables
# ---------------------------------------
# Leave VITE_API_URL empty when running locally! 
# This ensures your Vite proxy (in vite.config.ts) handles the requests and prevents CORS errors.
# 
# When deploying to Vercel, add this exact variable name in the Vercel Dashboard
# and set it to your Render server URL (e.g., https://travel-agency.onrender.com)
VITE_API_URL=
